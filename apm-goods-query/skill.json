{
  "name": "apm-goods-query",
  "version": "0.1.0",
  "description": "Search and analyze goods from APM Zoom platform with AI (local LLM + vision model)",
  "command": "apm-goods",
  "category": "data-query",
  "author": "APM AI Team",
  "runtime": "python",
  "entrypoint": "src/apm-goods-query.py",
  "dependencies": {
    "services": [],
    "agents": [],
    "tools": [],
    "llm": {
      "text": { "model": "qwen3-30b", "provider": "omlx", "optional": true },
      "vision": { "model": "minicpm-v:8b", "provider": "ollama", "optional": true }
    },
    "data": ["data/goods.db"]
  },
  "permissions": ["read_only"],
  "config": {
    "APM_OMLX_URL": { "default": "http://localhost:8000", "description": "Text LLM endpoint" },
    "APM_OLLAMA_URL": { "default": "http://localhost:11434", "description": "Vision LLM endpoint" },
    "APM_DB_PATH": { "default": "./data/goods.db", "description": "SQLite database path" }
  }
}
