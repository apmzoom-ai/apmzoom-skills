{
  "name": "apm-goods-query",
  "version": "0.3.0",
  "description": "Search and query goods from APM Zoom platform via remote API",
  "command": "apm-goods",
  "category": "data-query",
  "author": "APM AI Team",
  "runtime": "python",
  "entrypoint": "src/apm-goods-query.py",
  "worker": {
    "runtime": "cloudflare-workers",
    "entrypoint": "../worker/src/index.ts"
  },
  "dependencies": {
    "services": ["apm-zoom-api"],
    "agents": [],
    "tools": []
  },
  "permissions": ["read_only"],
  "config": {
    "APM_ACCOUNT": { "required": true, "description": "APM Zoom login account" },
    "APM_PASSWORD": { "required": true, "description": "APM Zoom login password", "secret": true },
    "APM_API_BASE": { "default": "https://44k2t5n59e.execute-api.ap-northeast-2.amazonaws.com", "description": "APM API base URL" }
  }
}
