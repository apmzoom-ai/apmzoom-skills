{
  "name": "apm-goods-query",
  "version": "0.4.0",
  "description": "Search and query 27K+ goods from APM Zoom Korean fashion e-commerce platform",
  "command": "apm-goods-query",
  "category": "e-commerce",
  "author": "APM AI Team",
  "license": "MIT",
  "homepage": "https://github.com/apmzoom-ai/apmzoom-skills",
  "api": {
    "base_url": "https://skiil.apmzoom.ai",
    "endpoints": [
      "GET /api/goods",
      "GET /api/goods/:id",
      "GET /api/categories",
      "GET /api/health"
    ]
  },
  "install": {
    "clawhub": "clawhub install apm-goods-query",
    "claude-code": "cp -r install/claude-code ~/.claude/skills/apm-goods-query",
    "mcp": "See install/mcp/"
  },
  "tags": ["e-commerce", "fashion", "korea", "goods-search", "api", "korean-fashion"],
  "permissions": ["read_only"]
}
